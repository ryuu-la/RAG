# ╔══════════════════════════════════════════════════╗
# ║         RAG Studio — Environment Config          ║
# ╠══════════════════════════════════════════════════╣
# ║  Copy this file as .env and add your API key:    ║
# ║    cp .env.example .env                          ║
# ║                                                  ║
# ║  Place .env in EITHER:                           ║
# ║    • RAG/.env           (project root)           ║
# ║    • RAG/backend/.env   (backend folder)         ║
# ║                                                  ║
# ║  Get a free API key at:                          ║
# ║    https://aistudio.google.com/apikey             ║
# ╚══════════════════════════════════════════════════╝

# ── REQUIRED ──────────────────────────────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ── Embedding & Retrieval (optional, defaults shown) ──
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
TOP_K=6

# ── Chunking (optional) ──────────────────────────
CHUNK_SIZE=1400
CHUNK_OVERLAP=200
MAX_CONTEXT_TOKENS=5000

# ── OCR (optional, for scanned PDFs) ─────────────
OCR_ENABLED=true
OCR_MIN_CHARS_PER_PAGE=40

# ── Storage paths (optional) ─────────────────────
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
CHROMA_DIR=./data/chroma
MODEL_CACHE_DIR=./data/models
CHROMA_COLLECTION=rag_chunks
